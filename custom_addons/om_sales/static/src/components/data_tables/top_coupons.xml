<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="om_sales.TopCouponsTable" owl="1">
        <div class="card dash-card h-100">
            <div class="card-header bg-white">
                <h5 class="mb-0" style="font-weight: 700; font-size: 1rem; color: #1a1a2e; letter-spacing: 0.3px;">
                    <i class="fa fa-tags me-2" style="color: #ef4444;"></i>
                    Mã Giảm Giá Phổ Biến
                </h5>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0 dash-table">
                    <thead>
                        <tr>
                            <th>Mã giảm giá</th>
                            <th class="text-center">Số lần dùng</th>
                            <th class="text-end">Khuyến mãi</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="props.items || []" t-as="coupon" t-key="coupon.name">
                            <tr>
                                <td>
                                    <span t-attf-style="
                                        display: inline-block;
                                        padding: 4px 12px;
                                        border-radius: 20px;
                                        font-weight: 700;
                                        font-size: 0.85rem;
                                        letter-spacing: 0.5px;
                                        color: #fff;
                                        background: {{ ['#6366f1','#f59e0b','#10b981','#ef4444','#3b82f6'][coupon_index % 5] }};
                                        box-shadow: 0 2px 6px {{ ['rgba(99,102,241,0.35)','rgba(245,158,11,0.35)','rgba(16,185,129,0.35)','rgba(239,68,68,0.35)','rgba(59,130,246,0.35)'][coupon_index % 5] }};
                                    " t-esc="coupon.name"/>
                                </td>
                                <td class="text-center fw-bold" t-esc="coupon.count"/>
                                <td class="text-end fw-bold">
                                    <t t-if="coupon.discount_type === 'percentage'">
                                        <span style="color: #10b981; font-size: 0.95rem;">
                                            <t t-esc="coupon.discount_value"/>%
                                        </span>
                                    </t>
                                    <t t-else="">
                                        <span style="color: #ef4444; font-size: 0.95rem;">
                                            <t t-esc="props.formatCurrency(coupon.discount_value)"/>
                                        </span>
                                    </t>
                                </td>
                            </tr>
                        </t>
                        <tr t-if="!props.items || props.items.length === 0">
                            <td colspan="3" class="text-center text-muted py-4">Chưa có dữ liệu</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </t>
</templates>

