<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="om_sales.KpiCard" owl="1">
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="card dash-card h-100">
                    <div class="card-body d-flex justify-content-between align-items-center">
                        <div>
                            <div class="kpi-title text-uppercase">Tổng sản phẩm</div>
                            <div class="kpi-value" t-esc="props.data.total_laptops">0</div>
                        </div>
                        <div class="icon-wrapper icon-box-primary">
                            <i class="fa fa-laptop"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card dash-card h-100">
                    <div class="card-body d-flex justify-content-between align-items-center">
                        <div>
                            <div class="kpi-title text-uppercase">Tổng đơn hàng</div>
                            <div class="kpi-value" t-esc="props.data.order_count">0</div>
                        </div>
                        <div class="icon-wrapper icon-box-success">
                            <i class="fa fa-shopping-cart"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card dash-card h-100">
                    <div class="card-body d-flex flex-column justify-content-between">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <div>
                                <div class="kpi-title text-uppercase">Tổng doanh thu</div>
                                <div class="kpi-value">
                                    <t t-esc="props.formatCurrency(props.data.total_revenue)"/>
                                </div>
                            </div>
                            <div class="icon-wrapper icon-box-info">
                                <i class="fa fa-money"></i>
                            </div>
                        </div>
                        <div t-if="props.data.mom_growth !== undefined" class="kpi-stat">
                            <span t-attf-class="{{ props.data.mom_growth >= 0 ? 'stat-up' : 'stat-down' }}">
                                <i t-attf-class="fa {{ props.data.mom_growth >= 0 ? 'fa-arrow-up' : 'fa-arrow-down' }} me-1"></i>
                                <t t-esc="props.data.mom_growth"/>% so với tháng trước
                            </span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card dash-card h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div class="kpi-title text-uppercase mb-0">Tình trạng đơn</div>
                            <div class="icon-wrapper icon-box-warning">
                                <i class="fa fa-cogs"></i>
                            </div>
                        </div>
                        <div>
                            <div class="d-flex justify-content-between border-bottom border-dark border-opacity-10 pb-1 mb-1">
                                <span>Đang xử lý:</span>
                                <span class="fw-bold" t-esc="props.data.pending_count">0</span>
                            </div>
                            <div class="d-flex justify-content-between border-bottom border-dark border-opacity-10 pb-1 mb-1">
                                <span>Đã giao:</span>
                                <span class="fw-bold text-success" t-esc="props.data.done_count">0</span>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span>Đã huỷ:</span>
                                <span class="fw-bold text-danger" t-esc="props.data.cancel_count">0</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>

