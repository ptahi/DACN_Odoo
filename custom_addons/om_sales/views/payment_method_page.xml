<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="payment_method_page" name="Payment Method Page">
        <t t-call="om_sales.website_layout">

            <div class="container mt-5 mb-5">

                <h2 class="text-center mb-4">
                    Chọn phương thức thanh toán
                </h2>

                <!-- ========================= -->
                <!-- THÔNG TIN ĐƠN HÀNG -->
                <!-- ========================= -->

                <div class="row">
                    <div class="col-md-8 mx-auto">
                        <div class="card mb-4 shadow-sm">
                            <div class="card-body">
                                <h5 class="card-title">Chi tiết thanh toán</h5>
                                <hr/>

                                <t t-if="order">
                                     <div class="d-flex justify-content-between mb-2">
                                        <span>Mã đơn hàng:</span>
                                        <strong><t t-esc="order.name"/></strong>
                                    </div>
                                    <div class="d-flex justify-content-between mb-2">
                                        <span>Tổng tiền:</span>
                                        <span class="fw-bold">
                                            <t t-esc="order.total_price" t-options='{"widget": "monetary", "display_currency": website.currency_id}'/> VND
                                        </span>
                                    </div>
                                </t>

                                <t t-else="">
                                    <div class="d-flex justify-content-between mb-2">
                                        <span>Tổng tiền hàng:</span>
                                        <strong id="display_subtotal">
                                            <t t-esc="total_price" t-options='{"widget": "float", "precision": 0}'/> VND
                                        </strong>
                                    </div>
                                    <div class="d-flex justify-content-between mb-2 text-success">
                                        <span>Giảm giá:</span>
                                        <strong id="display_discount">
                                            <t t-esc="discount_amount" t-options='{"widget": "float", "precision": 0}'/> VND
                                        </strong>
                                    </div>
                                    <hr/>
                                    <div class="d-flex justify-content-between mb-2">
                                        <span class="h5">Thành tiền:</span>
                                        <strong class="h5 text-danger" id="display_total">
                                            <t t-esc="final_price" t-options='{"widget": "float", "precision": 0}'/> VND
                                        </strong>
                                    </div>
                                </t>
                            </div>
                        </div>

                        <!-- COUPON INPUT - Nhập nhiều mã cùng lúc -->
                        <t t-if="not order">
                            <div class="card mb-4 shadow-sm o_coupon_section">
                                <div class="card-body">
                                    <label class="form-label fw-bold">Mã giảm giá</label>
                                    <p class="text-muted small mb-2">Nhập nhiều mã, cách nhau bằng dấu phẩy hoặc xuống dòng</p>
                                    <div class="d-flex gap-2 mb-2">
                                        <textarea id="coupon_code" class="form-control" rows="2" placeholder="Ví dụ: SALE10, NEWUSER, WELCOME"></textarea>
                                        <button class="btn btn-outline-primary" type="button" id="btn_apply_coupon" style="height: fit-content;">Áp dụng</button>
                                    </div>
                                    <div id="coupon_message" class="mt-2"></div>
                                    <div id="applied_coupons_list" class="mt-3" style="display: none;">
                                        <div class="border rounded p-3 bg-light">
                                            <strong class="text-success">Đang sử dụng:</strong>
                                            <ul id="applied_coupons_items" class="mb-0 mt-2 list-unstyled"></ul>
                                            <div class="mt-2">
                                                <strong>Tổng giảm:</strong>
                                                <span id="applied_total_discount" class="text-success fw-bold"></span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </div>
                </div>


                <!-- ========================= -->
                <!-- PAYMENT METHODS -->
                <!-- ========================= -->
                <div class="row justify-content-center">

                    <!-- COD -->
                    <div class="col-md-4 mb-3">
                        <div class="card h-100 shadow-sm btn-outline-primary o_btn_payment_cod" style="cursor: pointer;" data-url="/order/cod">
                            <div class="card-body text-center d-flex flex-column justify-content-center align-items-center">
                                <h1 class="mb-3">🚚</h1>
                                <h4>Thanh toán khi nhận hàng (COD)</h4>
                                <p class="text-muted small">Thanh toán tiền mặt cho shipper</p>
                            </div>
                        </div>
                    </div>

                    <!-- QR -->
                    <div class="col-md-4 mb-3">
                        <div class="card h-100 shadow-sm border-success btn-outline-success o_btn_payment_qr" style="cursor: pointer;" data-url="/order/qr">
                            <div class="card-body text-center d-flex flex-column justify-content-center align-items-center">
                                <h1 class="mb-3">📱</h1>
                                <h4 class="text-success">Thanh toán chuyển khoản/QR</h4>
                                <p class="text-muted small">Quét mã QR để thanh toán</p>
                            </div>
                        </div>
                    </div>

                </div>

            </div>

        </t>
    </template>
</odoo>
