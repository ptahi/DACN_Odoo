<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="om_sales.TopProductsTable" owl="1">
        <div class="card dash-card h-100">
            <div class="card-header bg-white">
                <h5 class="mb-0" style="font-weight: 700; font-size: 1rem; color: #1a1a2e; letter-spacing: 0.3px;">
                    <i class="fa fa-trophy me-2" style="color: #f59e0b;"></i>
                    Top Sản Phẩm Bán Chạy
                </h5>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0 dash-table">
                    <thead>
                        <tr>
                            <th>Sản phẩm</th>
                            <th class="text-center">Số lượng</th>
                            <th class="text-end">Doanh thu</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="props.items || []" t-as="product" t-key="product.code">
                            <tr>
                                <td>
                                    <span t-esc="product.name"/>
                                    <small class="text-muted d-block" t-esc="product.code"/>
                                </td>
                                <td class="text-center fw-bold" t-esc="product.qty"/>
                                <td class="text-end text-success fw-bold">
                                    <t t-esc="props.formatCurrency(product.revenue)"/>
                                </td>
                            </tr>
                        </t>
                        <tr t-if="!props.items || props.items.length === 0">
                            <td colspan="3" class="text-center text-muted py-4">Chưa có dữ liệu</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </t>
</templates>

